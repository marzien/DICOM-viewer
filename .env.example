# Copy this file to .env and adjust values before running docker compose

# Orthanc
ORTHANC_USERNAME=admin
ORTHANC_PASSWORD=orthanc

# PostgreSQL
POSTGRES_DB=imaging
POSTGRES_USER=imaging
POSTGRES_PASSWORD=imaging_secret

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=ai-results

# imaging-api
IMAGING_API_PORT=8080
ORTHANC_BASE_URL=http://orthanc:8042
AI_INFERENCE_URL=http://ai-inference:8000
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/imaging
SPRING_DATASOURCE_USERNAME=imaging
SPRING_DATASOURCE_PASSWORD=imaging_secret

# ai-inference
AI_INFERENCE_PORT=8000
MINIO_ENDPOINT=http://minio:9000
